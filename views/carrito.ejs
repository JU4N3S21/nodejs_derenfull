<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrito de Compras</title>
    <link rel="stylesheet" href="/css/carrito.css">
    <link rel="icon" href="/img/logo/logo_fondo_negro-removebg-preview.png">
</head>
<body>
    <header class="header">
        <div class="menu container">
            <a href="/" class="logo">
                <img src="/img/logo/LOGO MENU PAGINA WEB.png" alt="">
            </a>
            <a href="/" class="btn-volver">Volver a la tienda</a>
        </div>
    </header>

    <main class="container">
        <h2>Tu Carrito</h2>

        <table id="carrito-detalle">
            <thead>
                <tr>
                    <th>Imagen</th>
                    <th>Producto</th>
                    <th>Precio</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <div id="main-content">
            <button id="pagar" class="btn-1">Pagar</button>
            <button id="vaciar-carrito" class="btn-1">Vaciar Carrito</button>
        </div>
    </main>

    <script src="/js/carrito.js"></script>
</body>
</html>